    'amman': [31.9454, 35.9284], 'jordan': [31.5, 36.0], 'petra': [30.3285, 35.4444],
    'wadi rum': [29.5321, 35.4110], 'dead sea': [31.5000, 35.4732], 'aqaba': [29.5267, 35.0078],
    'madaba': [31.7178, 35.7936], 'jerash': [32.2747, 35.8961], 'mount nebo': [31.7670, 35.7253],
    'karak': [31.1851, 35.7047], 'dana': [30.6296, 35.6271], 'ajloun': [32.3326, 35.7525],
    'irbid': [32.5568, 35.8469], 'kerak': [31.1851, 35.7047], 'salt': [32.0392, 35.7272],
    'azraq': [31.8314, 36.8271], 'um qais': [32.6530, 35.6830], 'umm qais': [32.6530, 35.6830],
    'wadi mujib': [31.4641, 35.5754], 'bethany': [31.8372, 35.5493], 'shobak': [30.5294, 35.5649],
    'ma\'in': [31.6103, 35.6336], 'main hot springs': [31.6103, 35.6336]
};

function findCoords(dest) {
    if (!dest) return null;
    var d = dest.toLowerCase().trim();
    for (var k in knownCoords) {
        if (d.indexOf(k) >= 0) return knownCoords[k];
    }
    return null;
}

var mapEl = document.getElementById('tripMap');
if (mapEl) {
    var map = L.map('tripMap', { scrollWheelZoom: false });
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '© OpenStreetMap',
        maxZoom: 18
    }).addTo(map);

    var dayStops = [
        @if($itinerary && $itinerary->days)
        @foreach($itinerary->days->sortBy('day_number') as $day)
        { day: {{ $day->day_number }}, dest: '{{ addslashes($day->destinations ?: 'Jordan') }}' },
        @endforeach
        @endif
    ];

    var markers = [];
    var latlngs = [];
    var bounds = [];

    dayStops.forEach(function(s) {
        var c = findCoords(s.dest);
        if (!c) {
            // Add slight offset from Jordan center for unknown destinations
            c = [31.5 + (Math.random() - 0.5) * 0.5, 36.0 + (Math.random() - 0.5) * 0.5];
        }
        var icon = L.divIcon({
            className: '',
            html: '<div class="map-marker">' + s.day + '</div>',
            iconSize: [28, 28],
            iconAnchor: [14, 14]
        });
        var m = L.marker(c, { icon: icon }).addTo(map);
        m.bindPopup('<strong>Day ' + s.day + '</strong><br>' + s.dest);
        markers.push(m);
        latlngs.push(c);
        bounds.push(c);
    });

    if (latlngs.length > 1) {
        L.polyline(latlngs, { color: '#1a5c45', weight: 3, opacity: 0.7, dashArray: '8 6' }).addTo(map);
    }

    if (bounds.length > 0) {
        map.fitBounds(bounds, { padding: [40, 40] });
    } else {
        map.setView([31.5, 36.0], 7);
    }
}
</script>
</body>
</html>
