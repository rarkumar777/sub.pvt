.day-accom-card{background:#f9fafb;border:1px solid #e5e7eb;border-radius:10px;overflow:hidden;margin-top:16px;}
.day-accom-header{font-size:12px;font-weight:600;color:#888;text-transform:uppercase;letter-spacing:.5px;padding:12px 16px;border-bottom:1px solid #e5e7eb;}
.day-accom-body{display:flex;gap:16px;padding:16px;align-items:center;}
