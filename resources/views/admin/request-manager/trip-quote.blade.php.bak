/* ── Price Section ── */
.price-section{max-width:1060px;margin:0 auto;padding:0 32px 48px;}
.price-section h2{font-family:'Playfair Display',serif;font-size:28px;font-weight:700;color:#1a1a1a;margin-bottom:24px;}
