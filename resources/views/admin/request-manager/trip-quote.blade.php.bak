<script>
document.querySelectorAll('.pv-nav-links a').forEach(function(a){
    a.addEventListener('click',function(e){
        document.querySelectorAll('.pv-nav-links a').forEach(function(x){x.classList.remove('active');});
        this.classList.add('active');
    });
});

