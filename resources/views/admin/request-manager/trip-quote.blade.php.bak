@php
    $totalPax = ($tripRequest->adults ?? 0) + ($tripRequest->children ?? 0);
    if($totalPax < 1) $totalPax = 1;
    $dayCount = ($itinerary && $itinerary->days) ? $itinerary->days->count() : 0;
    $groupTotal = $itinerary ? ($itinerary->group_total ?? 0) : 0;
    $ppp = $itinerary ? ($itinerary->price_per_person ?? 0) : 0;
    $currency = $tripRequest->currency ?? 'USD';
    $sym = '$'; if($currency=='EUR') $sym='€'; elseif($currency=='JOD') $sym='JOD ';
    $depDate = $tripRequest->departure_date ? \Carbon\Carbon::parse($tripRequest->departure_date) : null;
    $retDate = $tripRequest->return_date ? \Carbon\Carbon::parse($tripRequest->return_date) : null;
    $dateRange = ($depDate && $retDate) ? $depDate->format('d M').' to '.$retDate->format('d M Y') : 'Flexible';
    $itinTitle = $itinerary ? ($itinerary->title ?: 'Trip to Jordan for '.$dayCount.' '.($dayCount==1?'day':'days')) : 'Your Trip to Jordan';
    $destination = $itinerary && $itinerary->title ? $itinerary->title : 'Jordan';
@endphp
<style>
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'Inter',sans-serif;background:#fff;color:#333;}
a{text-decoration:none;}

/* ── Sticky Nav ── */
.pv-nav{position:sticky;top:0;z-index:50;background:#1a5c45;display:flex;align-items:center;justify-content:space-between;padding:0 32px;height:52px;box-shadow:0 2px 8px rgba(0,0,0,.1);}
.pv-nav-left{display:flex;align-items:center;gap:28px;height:100%;}
.pv-nav-brand{font-family:'Playfair Display',serif;font-size:22px;font-weight:700;color:#fff;letter-spacing:.5px;}
.pv-nav-links{display:flex;align-items:center;gap:0;height:100%;}
.pv-nav-links a{color:rgba(255,255,255,.7);font-size:14px;font-weight:500;padding:0 18px;height:100%;display:flex;align-items:center;border-bottom:3px solid transparent;transition:all .15s;}
.pv-nav-links a:hover,.pv-nav-links a.active{color:#fff;border-bottom-color:#e8d48b;}
.pv-nav-right{display:flex;flex-direction:column;align-items:flex-end;gap:2px;}
.pv-nav-price{color:#fff;font-size:15px;font-weight:700;line-height:1.2;}
.pv-nav-price span{font-size:11px;color:rgba(255,255,255,.5);font-weight:400;margin-left:4px;}
.pv-nav-detail{color:#e8d48b;font-size:11px;font-weight:600;text-decoration:underline;}

/* ── Quote Header ── */
.quote-header{max-width:1060px;margin:0 auto;padding:40px 32px 32px;display:flex;gap:40px;align-items:flex-start;}
.quote-left{flex:1;}
.quote-left h1{font-family:'Playfair Display',serif;font-size:30px;font-weight:700;font-style:italic;color:#1a1a1a;margin-bottom:16px;line-height:1.25;}
.quote-left .divider{width:100%;max-width:500px;height:1px;background:#e5e7eb;margin-bottom:16px;}
.quote-meta{display:flex;align-items:center;gap:20px;flex-wrap:wrap;font-size:13px;color:#555;}
.quote-meta-item{display:flex;align-items:center;gap:6px;}
.quote-meta-item i{color:#1a5c45;font-size:12px;}

/* Agent Card */
.agent-card{background:#f9f8f5;border:1px solid #e5e7eb;border-radius:8px;padding:24px;width:320px;flex-shrink:0;}
.agent-card-title{font-size:14px;color:#666;margin-bottom:16px;font-weight:500;font-style:italic;}
.agent-body{display:flex;gap:14px;align-items:flex-start;}
.agent-avatar{width:64px;height:64px;border-radius:50%;background:#1a5c45;color:#fff;display:flex;align-items:center;justify-content:center;font-size:24px;font-weight:700;flex-shrink:0;overflow:hidden;}
.agent-avatar img{width:100%;height:100%;object-fit:cover;}
.agent-info h4{font-size:16px;font-weight:700;color:#1a1a1a;margin-bottom:2px;}
.agent-info p{font-size:12px;color:#666;line-height:1.6;margin:0;}
.agent-info .stars{color:#e8b445;font-size:12px;margin-top:6px;}
.agent-info .stars span{color:#888;font-size:11px;margin-left:4px;}

/* ── Features Strip ── */
.features{background:#f5f9f8;border-top:1px solid #e5e7eb;border-bottom:1px solid #e5e7eb;padding:32px 0;}
.features-inner{max-width:1060px;margin:0 auto;padding:0 32px;display:grid;grid-template-columns:repeat(3,1fr);gap:32px;}
.feat{display:flex;gap:14px;align-items:flex-start;}
.feat-icon{width:40px;height:40px;border-radius:10px;background:#e0f0ec;color:#1a5c45;display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0;}
.feat h4{font-size:14px;font-weight:700;color:#1a1a1a;margin-bottom:4px;}
.feat p{font-size:12px;color:#888;line-height:1.6;}

/* ── Journey Overview ── */
.journey{max-width:1060px;margin:0 auto;padding:48px 32px;}
.journey-inner{display:flex;gap:48px;}
.journey-map{flex:1;border-radius:12px;min-height:400px;position:relative;overflow:hidden;}
#tripMap{width:100%;height:100%;min-height:400px;border-radius:12px;z-index:1;}
.map-marker{width:28px;height:28px;border-radius:50%;background:#1a5c45;color:#fff;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;border:3px solid #fff;box-shadow:0 2px 8px rgba(0,0,0,.3);}
.journey-list{width:320px;flex-shrink:0;}
.journey-list h3{font-family:'Playfair Display',serif;font-size:24px;font-weight:700;color:#1a1a1a;margin-bottom:24px;line-height:1.3;}
.jday{display:flex;gap:12px;align-items:flex-start;position:relative;padding-bottom:20px;}
.jday:last-child{padding-bottom:0;}
.jday::before{content:'';position:absolute;top:16px;left:5px;width:2px;height:calc(100% - 4px);background:#d1d5db;}
.jday:last-child::before{display:none;}
.jday-dot{width:12px;height:12px;border-radius:50%;border:3px solid #1a5c45;background:#fff;margin-top:4px;flex-shrink:0;position:relative;z-index:1;}
.jday-info .lbl{font-size:13px;font-weight:700;color:#1a5c45;}
.jday-info .dest{font-size:12px;color:#888;display:flex;align-items:center;gap:4px;margin-top:2px;}
.jday-info .dest i{font-size:10px;color:#aaa;}

/* ── Day by Day Detail (Evaneos Style) ── */
.dbd{max-width:1060px;margin:0 auto;padding:0 32px 48px;}
.dbd h2{font-family:'Playfair Display',serif;font-size:28px;font-weight:700;color:#1a1a1a;margin-bottom:32px;}

.day-block{margin-bottom:40px;}
.day-hero{position:relative;width:100%;height:280px;border-radius:12px;overflow:hidden;margin-bottom:20px;}
.day-hero img{width:100%;height:100%;object-fit:cover;}
.day-hero-overlay{position:absolute;bottom:0;left:0;right:0;padding:20px 24px;background:linear-gradient(transparent,rgba(0,0,0,.6));}
.day-hero-label{font-size:12px;font-weight:700;color:#e8d48b;text-transform:uppercase;letter-spacing:1px;}
.day-hero-title{font-family:'Playfair Display',serif;font-size:22px;font-weight:700;color:#fff;margin-top:4px;}
.day-no-photo{width:100%;height:160px;border-radius:12px;background:#eef2f0;display:flex;align-items:center;justify-content:center;margin-bottom:20px;color:#aaa;}

.day-content{padding:0 8px;}
.day-loc-badge{display:inline-block;background:#f0f0f0;color:#555;font-size:11px;font-weight:700;padding:4px 12px;border-radius:4px;text-transform:uppercase;letter-spacing:.5px;margin-bottom:12px;}
.day-title-text{font-size:18px;font-weight:700;color:#1a5c45;margin-bottom:12px;}
